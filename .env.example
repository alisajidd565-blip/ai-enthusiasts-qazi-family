# Copy to `.env.local` and fill values (never commit `.env.local`).

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cloudinary (Dashboard → API Keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Groq (https://console.groq.com → API Keys)
GROQ_API_KEY=your_groq_api_key
# Optional: override default vision model (default: meta-llama/llama-4-scout-17b-16e-instruct)
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Single admin password (pick a long random string)
ADMIN_PASSWORD=change-me-to-something-long-and-random

# Used to sign admin session cookies (generate: openssl rand -hex 32)
ADMIN_JWT_SECRET=change-me-to-a-long-random-secret
